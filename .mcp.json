{
  "name": "sql-builder-ai-mcp",
  "description": "Sql Builder Ai automation via MCP. Includes build select, build insert, explain query. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "build_select",
      "description": "Build a SELECT SQL query from structured parameters.",
      "parameters": {
        "type": "object",
        "properties": {
          "table": {
            "type": "string"
          },
          "columns": {
            "type": "array"
          },
          "where": {
            "type": "object"
          },
          "order_by": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "joins": {
            "type": "array"
          }
        },
        "required": [
          "table"
        ]
      }
    },
    {
      "name": "build_insert",
      "description": "Build an INSERT SQL query from a list of row dicts.",
      "parameters": {
        "type": "object",
        "properties": {
          "table": {
            "type": "string"
          },
          "rows": {
            "type": "array"
          },
          "on_conflict": {
            "type": "string"
          }
        },
        "required": [
          "table",
          "rows"
        ]
      }
    },
    {
      "name": "explain_query",
      "description": "Analyze and explain a SQL query's structure and components.",
      "parameters": {
        "type": "object",
        "properties": {
          "sql": {
            "type": "string"
          }
        },
        "required": [
          "sql"
        ]
      }
    },
    {
      "name": "optimize_query_hints",
      "description": "Suggest optimizations for a SQL query.",
      "parameters": {
        "type": "object",
        "properties": {
          "sql": {
            "type": "string"
          }
        },
        "required": [
          "sql"
        ]
      }
    }
  ]
}